# ============================================================
# Radhe Digital — API Server Environment Variables
# Copy this file to .env and fill in your Hostinger MySQL values
# ============================================================

# MySQL Database (Hostinger credentials)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_hostinger_db_user
DB_PASSWORD=your_hostinger_db_password
DB_NAME=radhedigital

# Server port (set automatically by Replit; set manually on Hostinger)
PORT=8080

# Node environment
NODE_ENV=production
